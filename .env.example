# ============================================================
# 股票数据库系统 - 环境变量配置
# 复制此文件为 .env 并修改配置
# ⚠️ 重要: .env 文件不应提交到GitHub (已在.gitignore中)
# ============================================================

# ============ 数据库配置 ============
# 支持三种数据库类型：

# 1. SQLite (本地开发，默认)
# 适合个人使用，数据存储在本地文件
DATABASE_URL=sqlite:///./data/stock_db.sqlite

# 2. PostgreSQL (共享数据库，推荐团队使用)
# 需要安装: pip install psycopg2-binary
# DATABASE_URL=postgresql://username:password@localhost:5432/stock_db
# 或使用Docker: postgresql://stock_user:stock_pass@db:5432/stock_db

# 3. MySQL (共享数据库)
# 需要安装: pip install pymysql
# DATABASE_URL=mysql://username:password@localhost:3306/stock_db

# PostgreSQL连接池配置 (仅PostgreSQL/MySQL有效)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ============ 日志配置 ============
LOG_LEVEL=INFO
# 日志路径 (可选，默认为项目目录下的logs文件夹)
# LOG_PATH=/path/to/logs

# ============ AKShare配置 ============
# 请求间隔(秒)，防止被封
AKSHARE_REQUEST_DELAY=0.5
# 最大重试次数
AKSHARE_MAX_RETRIES=3
# 请求超时(秒)
AKSHARE_TIMEOUT=30

# ============ 数据更新配置 ============
# 更新开始/结束时间 (24小时制)
UPDATE_START_TIME=09:00
UPDATE_END_TIME=17:00

# ============ 回测配置 ============
# 初始资金
INITIAL_CAPITAL=1000000.0
# 手续费率
COMMISSION_RATE=0.0003
# 滑点
SLIPPAGE=0.0001

# ============ PostgreSQL Docker配置 (可选) ============
# 仅在使用 docker-compose 启动PostgreSQL时需要
DB_USER=stock_user
DB_PASSWORD=your_secure_password_here
DB_NAME=stock_db

# ============ GitHub/GitLab配置 ============
# 远程仓库URL (可选)
GIT_REMOTE_URL=
